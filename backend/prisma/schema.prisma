generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  WORKER
  CUSTOMER
  ADMIN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DocumentType {
  AADHAAR
  PAN
  DRIVING_LICENSE
  BANK_STATEMENT
  SKILL_CERTIFICATE
  OTHER
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  JOB
  PAYMENT
  SYSTEM
  WELFARE
  SCORE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  phone           String    @unique
  passwordHash    String    @map("password_hash")
  role            UserRole  @default(WORKER)
  fullName        String    @map("full_name")
  avatarUrl       String?   @map("avatar_url")
  isVerified      Boolean   @default(false) @map("is_verified")
  isActive        Boolean   @default(true) @map("is_active")
  otp             String?
  otpExpiresAt    DateTime? @map("otp_expires_at")
  refreshToken    String?   @map("refresh_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workerProfile   WorkerProfile?
  customerProfile CustomerProfile?
  documents       Document[]
  wallet          Wallet?
  notifications   Notification[]
  reviewsGiven    Review[]  @relation("ReviewerRelation")
  reviewsReceived Review[]  @relation("RevieweeRelation")

  @@map("users")
}

model WorkerProfile {
  id                      String    @id @default(uuid())
  userId                  String    @unique @map("user_id")
  bio                     String?
  city                    String?
  state                   String?
  pincode                 String?
  latitude                Decimal?  @db.Decimal(10, 8)
  longitude               Decimal?  @db.Decimal(11, 8)
  yearsExperience         Int       @default(0) @map("years_experience")
  gigScore                Int       @default(0) @map("gig_score")
  incomeConsistencyScore  Int       @default(0) @map("income_consistency_score")
  customerRatingScore     Decimal   @default(0) @db.Decimal(3, 2) @map("customer_rating_score")
  jobCompletionScore      Int       @default(0) @map("job_completion_score")
  experienceScore         Int       @default(0) @map("experience_score")
  financialBehaviourScore Int       @default(0) @map("financial_behaviour_score")
  digitalReputationScore  Int       @default(0) @map("digital_reputation_score")
  totalJobsCompleted      Int       @default(0) @map("total_jobs_completed")
  totalEarnings           Decimal   @default(0) @db.Decimal(12, 2) @map("total_earnings")
  averageRating           Decimal   @default(0) @db.Decimal(3, 2) @map("average_rating")
  isAvailable             Boolean   @default(true) @map("is_available")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          WorkerSkill[]
  applications    JobApplication[]
  assignedJobs    Job[]
  earnings        Earning[]
  loanApplications LoanApplication[]
  schemeApplications SchemeApplication[]

  @@map("worker_profiles")
}

model CustomerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  companyName    String?  @map("company_name")
  businessType   String?  @map("business_type")
  city           String?
  state          String?
  gstNumber      String?  @map("gst_number")
  totalJobsPosted Int     @default(0) @map("total_jobs_posted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("customer_profiles")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String
  createdAt DateTime @default(now()) @map("created_at")

  workerSkills WorkerSkill[]

  @@map("skills")
}

model WorkerSkill {
  id         String     @id @default(uuid())
  workerId   String     @map("worker_id")
  skillId    String     @map("skill_id")
  level      SkillLevel @default(BEGINNER)
  isVerified Boolean    @default(false) @map("is_verified")
  verifiedAt DateTime?  @map("verified_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  skill  Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([workerId, skillId])
  @@map("worker_skills")
}

model Job {
  id               String    @id @default(uuid())
  customerId       String    @map("customer_id")
  title            String
  description      String
  category         String
  locationCity     String    @map("location_city")
  locationState    String    @map("location_state")
  locationAddress  String?   @map("location_address")
  latitude         Decimal?  @db.Decimal(10, 8)
  longitude        Decimal?  @db.Decimal(11, 8)
  budgetMin        Decimal   @db.Decimal(10, 2) @map("budget_min")
  budgetMax        Decimal   @db.Decimal(10, 2) @map("budget_max")
  durationDays     Int?      @map("duration_days")
  status           JobStatus @default(OPEN)
  requiredSkills   String[]  @map("required_skills")
  minGigScore      Int       @default(0) @map("min_gig_score")
  assignedWorkerId String?   @map("assigned_worker_id")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  customer       CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedWorker WorkerProfile?   @relation(fields: [assignedWorkerId], references: [id])
  applications   JobApplication[]
  reviews        Review[]
  transactions   Transaction[]
  earnings       Earning[]

  @@map("jobs")
}

model JobApplication {
  id           String            @id @default(uuid())
  jobId        String            @map("job_id")
  workerId     String            @map("worker_id")
  coverLetter  String?           @map("cover_letter")
  proposedRate Decimal?          @db.Decimal(10, 2) @map("proposed_rate")
  status       ApplicationStatus @default(PENDING)
  appliedAt    DateTime          @default(now()) @map("applied_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobId, workerId])
  @@map("job_applications")
}

model Review {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  reviewerId  String   @map("reviewer_id")
  revieweeId  String   @map("reviewee_id")
  rating      Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  reviewee User @relation("RevieweeRelation", fields: [revieweeId], references: [id])

  @@map("reviews")
}

model Document {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  documentType DocumentType @map("document_type")
  fileUrl      String       @map("file_url")
  fileName     String?      @map("file_name")
  isVerified   Boolean      @default(false) @map("is_verified")
  verifiedAt   DateTime?    @map("verified_at")
  verifiedBy   String?      @map("verified_by")
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  balance       Decimal  @default(0) @db.Decimal(12, 2)
  lockedBalance Decimal  @default(0) @db.Decimal(12, 2) @map("locked_balance")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id               String            @id @default(uuid())
  walletId         String            @map("wallet_id")
  type             TransactionType
  amount           Decimal           @db.Decimal(12, 2)
  status           TransactionStatus @default(PENDING)
  description      String?
  referenceId      String?           @map("reference_id")
  razorpayOrderId  String?           @map("razorpay_order_id")
  razorpayPaymentId String?          @map("razorpay_payment_id")
  jobId            String?           @map("job_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  job    Job?   @relation(fields: [jobId], references: [id])

  @@map("transactions")
}

model Earning {
  id        String   @id @default(uuid())
  workerId  String   @map("worker_id")
  jobId     String?  @map("job_id")
  amount    Decimal  @db.Decimal(12, 2)
  month     Int
  year      Int
  createdAt DateTime @default(now()) @map("created_at")

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  job    Job?          @relation(fields: [jobId], references: [id])

  @@map("earnings")
}

model GovernmentScheme {
  id                 String   @id @default(uuid())
  name               String
  description        String
  ministry           String?
  eligibilityCriteria Json?   @map("eligibility_criteria")
  benefits           String?
  applicationUrl     String?  @map("application_url")
  category           String?
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  applications SchemeApplication[]

  @@map("government_schemes")
}

model SchemeApplication {
  id        String   @id @default(uuid())
  workerId  String   @map("worker_id")
  schemeId  String   @map("scheme_id")
  status    String   @default("PENDING")
  appliedAt DateTime @default(now()) @map("applied_at")

  worker WorkerProfile    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  scheme GovernmentScheme @relation(fields: [schemeId], references: [id])

  @@map("scheme_applications")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model LoanApplication {
  id                    String   @id @default(uuid())
  workerId              String   @map("worker_id")
  amount                Decimal  @db.Decimal(12, 2)
  purpose               String?
  gigScoreAtApplication Int?     @map("gig_score_at_application")
  status                String   @default("PENDING")
  partnerBank           String?  @map("partner_bank")
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("loan_applications")
}